{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "emdash-sample",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "emdash-sample",
			"database_id": "1011de90-ed99-47d7-a973-0c8c0efe1857",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "emdash-sample-media",
		},
	],
}
